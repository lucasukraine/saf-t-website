---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const posts = (await getCollection('blog')).sort((a, b) => a.data.order - b.data.order);
const related = posts.filter((p) => p.id !== post.id).slice(0, 3);

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://saftconnector.com';
const pageUrl = `${siteUrl}/blog/${post.id}/`;

const fmt = new Intl.DateTimeFormat('uk-UA', { day: 'numeric', month: 'long', year: 'numeric' });
const pubLabel = fmt.format(post.data.pubDate);
const isoPub = post.data.pubDate.toISOString();
const isoMod = (post.data.updatedDate ?? post.data.pubDate).toISOString();

// ~180 wpm for Ukrainian long-form
const words = post.body ? post.body.split(/\s+/).length : 0;
const readMin = Math.max(3, Math.round(words / 180));

const articleSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      '@id': `${pageUrl}#article`,
      headline: post.data.title,
      description: post.data.description,
      inLanguage: 'uk',
      datePublished: isoPub,
      dateModified: isoMod,
      mainEntityOfPage: pageUrl,
      image: `${siteUrl}/og-image.jpg`,
      speakable: { '@type': 'SpeakableSpecification', cssSelector: ['.post-lead'] },
      author: {
        '@type': 'Organization',
        name: 'LUCAS',
        url: 'https://www.lucasua.com',
      },
      publisher: { '@id': `${siteUrl}/#organization` },
      about: { '@id': `${siteUrl}/#software` },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'SAF-T Connector', item: `${siteUrl}/` },
        { '@type': 'ListItem', position: 2, name: 'Блог', item: `${siteUrl}/blog/` },
        { '@type': 'ListItem', position: 3, name: post.data.title, item: pageUrl },
      ],
    },
  ],
});
---

<BaseLayout
  title={`${post.data.title} | SAF-T Connector`}
  description={post.data.description}
  theme="light"
  ogType="article"
  publishedTime={isoPub}
  modifiedTime={isoMod}
  schemaExtra={articleSchema}
>
  <article class="post">
    <div class="container">

      <nav class="post-crumbs" aria-label="Хлібні крихти">
        <a href="/">SAF-T Connector</a>
        <span aria-hidden="true">/</span>
        <a href="/blog/">Блог</a>
      </nav>

      <header class="post-head">
        <div class="sect-rule">
          <span class="sect-no">Блог</span>
          <span class="sect-label">{post.data.label}</span>
        </div>
        <h1 class="post-h1">{post.data.title}</h1>
        <p class="post-lead">{post.data.description}</p>
        <div class="post-meta">
          <time datetime={isoPub}>{pubLabel}</time>
          <span aria-hidden="true">·</span>
          <span>{readMin} хв читання</span>
          <span aria-hidden="true">·</span>
          <span>Команда LUCAS</span>
        </div>
      </header>

      <div class="prose">
        <Content />
      </div>

      <footer class="post-foot">
        <div class="post-note">
          Матеріал підготовлено командою LUCAS — аудиторської та технологічної компанії,
          розробника <a href="/">SAF-T Connector</a>. Інформація актуальна станом на дату
          публікації; нормативна база SAF-T UA розвивається — звіряйте деталі з офіційними
          джерелами ДПС та чинною редакцією ПКУ.
        </div>

        <div class="post-cta">
          <div>
            <p class="post-cta-h">Потрібна допомога із SAF-T UA?</p>
            <p class="post-cta-p">Розкажіть про вашу облікову систему — оцінимо готовність даних і запропонуємо підхід.</p>
          </div>
          <a href="/#contact" class="btn btn-orange">Запитати вартість <span class="btn-arrow" aria-hidden="true">→</span></a>
        </div>

        {related.length > 0 && (
          <div class="post-related">
            <div class="sect-rule">
              <span class="sect-label">Читайте також</span>
            </div>
            <ul class="rel-list">
              {related.map((p) => (
                <li>
                  <a href={`/blog/${p.id}/`} class="rel-link">
                    <span class="rel-label">{p.data.label}</span>
                    <span class="rel-title">{p.data.title}</span>
                    <span class="rel-arrow" aria-hidden="true">→</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </footer>

    </div>
  </article>
</BaseLayout>

<style>
.post { padding: 128px 0 96px; }
.post .container { max-width: 880px; }

.post-crumbs {
  display: flex;
  gap: 10px;
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: .04em;
  color: var(--ink-mute);
  margin-bottom: 28px;
}
.post-crumbs a { color: var(--ink-soft); }
.post-crumbs a:hover { color: var(--accent-text); }

.post-head { margin-bottom: 56px; }
.post-h1 {
  font-family: var(--display);
  font-weight: 600;
  font-size: clamp(30px, 3.4vw, 46px);
  letter-spacing: -0.03em;
  line-height: 1.08;
  color: var(--ink);
  margin-bottom: 20px;
  text-wrap: balance;
}
.post-lead {
  font-size: clamp(15.5px, 1.2vw, 17.5px);
  line-height: 1.7;
  color: var(--ink-soft);
  max-width: 64ch;
  margin-bottom: 22px;
}
.post-meta {
  display: flex;
  gap: 10px;
  align-items: baseline;
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: .05em;
  color: var(--ink-mute);
  border-top: 1px solid var(--line);
  padding-top: 16px;
}

/* ── Rendered markdown ── */
.prose { max-width: 72ch; }
.prose :global(h2) {
  font-family: var(--display);
  font-weight: 600;
  font-size: clamp(22px, 2vw, 28px);
  letter-spacing: -0.025em;
  line-height: 1.15;
  color: var(--ink);
  margin: 52px 0 18px;
  padding-top: 22px;
  border-top: 1px solid var(--line-strong);
}
.prose :global(h3) {
  font-family: var(--display);
  font-weight: 600;
  font-size: 18px;
  letter-spacing: -0.015em;
  color: var(--ink);
  margin: 30px 0 10px;
}
.prose :global(p) {
  font-family: var(--body);
  font-size: 15.5px;
  line-height: 1.8;
  color: var(--ink-soft);
  margin: 0 0 16px;
}
.prose :global(strong) { color: var(--ink); font-weight: 600; }
.prose :global(a) {
  color: var(--accent-text);
  text-decoration: underline;
  text-decoration-thickness: 1px;
  text-underline-offset: 3px;
}
.prose :global(ul), .prose :global(ol) {
  margin: 0 0 18px;
  padding: 0 0 0 2px;
  list-style: none;
}
.prose :global(li) {
  position: relative;
  padding: 8px 0 8px 22px;
  font-size: 15px;
  line-height: 1.7;
  color: var(--ink-soft);
  border-top: 1px solid var(--line);
}
.prose :global(li:first-child) { border-top: none; }
.prose :global(ul li::before) {
  content: "";
  position: absolute; left: 2px; top: 20px;
  width: 8px; height: 1.5px;
  background: var(--accent);
}
.prose :global(ol) { counter-reset: item; }
.prose :global(ol li) { padding-left: 30px; }
.prose :global(ol li::before) {
  counter-increment: item;
  content: counter(item, decimal-leading-zero);
  position: absolute; left: 0; top: 9px;
  font-family: var(--mono);
  font-size: 11px;
  font-weight: 600;
  color: var(--accent-text);
}
.prose :global(table) {
  width: 100%;
  border-collapse: collapse;
  margin: 8px 0 24px;
  font-size: 14px;
  line-height: 1.55;
}
.prose :global(thead th) {
  text-align: left;
  font-family: var(--mono);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--ink-mute);
  padding: 0 18px 10px 0;
  border-bottom: 1px solid var(--line-strong);
}
.prose :global(tbody td) {
  padding: 11px 18px 11px 0;
  border-bottom: 1px solid var(--line);
  color: var(--ink-soft);
  vertical-align: top;
}
.prose :global(tbody td:first-child) { color: var(--ink); font-weight: 600; }
.prose :global(blockquote) {
  margin: 22px 0;
  padding: 16px 22px;
  border-left: 2px solid var(--accent);
  background: var(--surface);
  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
}
.prose :global(blockquote p) { margin: 0; font-size: 14.5px; }
.prose :global(code) {
  font-family: var(--mono);
  font-size: .88em;
  background: var(--surface-2);
  border: 1px solid var(--line);
  border-radius: 5px;
  padding: 1px 6px;
  color: var(--ink);
}
.prose :global(hr) {
  border: none;
  border-top: 1px solid var(--line-strong);
  margin: 40px 0;
}

/* ── Footer blocks ── */
.post-foot { max-width: 72ch; }
.post-note {
  margin-top: 48px;
  padding-top: 20px;
  border-top: 1px solid var(--line-strong);
  font-family: var(--body);
  font-size: 13px;
  line-height: 1.7;
  color: var(--ink-mute);
}
.post-note a { color: var(--accent-text); text-decoration: underline; text-underline-offset: 3px; }

.post-cta {
  margin-top: 36px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 28px;
  background: var(--surface);
  border: 1px solid var(--line-strong);
  border-radius: var(--radius);
  box-shadow: var(--card-shadow);
  padding: 28px 32px;
}
.post-cta-h {
  font-family: var(--display);
  font-weight: 600;
  font-size: 19px;
  letter-spacing: -0.02em;
  color: var(--ink);
  margin-bottom: 6px;
}
.post-cta-p {
  font-size: 14px;
  line-height: 1.6;
  color: var(--ink-soft);
  max-width: 44ch;
}
.post-cta .btn { flex: none; }

.post-related { margin-top: 56px; }
.post-related .sect-rule { margin-bottom: 0; }
.rel-list { list-style: none; margin: 0; padding: 0; }
.rel-link {
  display: grid;
  grid-template-columns: 200px 1fr auto;
  gap: 20px;
  align-items: baseline;
  padding: 18px 0;
  border-bottom: 1px solid var(--line);
  transition: color .2s var(--ease);
}
.rel-label {
  font-family: var(--mono);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--ink-mute);
}
.rel-title {
  font-family: var(--display);
  font-weight: 600;
  font-size: 16.5px;
  letter-spacing: -0.015em;
  color: var(--ink);
  transition: color .2s var(--ease);
}
.rel-arrow { color: var(--ink-mute); transition: transform .2s var(--ease), color .2s var(--ease); }
.rel-link:hover .rel-title { color: var(--accent-text); }
.rel-link:hover .rel-arrow { color: var(--accent-text); transform: translateX(3px); }

@media (max-width: 720px) {
  .post { padding: 100px 0 64px; }
  .post-cta { flex-direction: column; align-items: flex-start; }
  .rel-link { grid-template-columns: 1fr auto; }
  .rel-label { display: none; }
}
</style>
