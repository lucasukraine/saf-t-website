---
// SaftExplainer.astro — AEO/GEO block: clear definitional content for answer engines

// Build date = last content review signal (site is rebuilt on every change)
const updatedLabel = new Intl.DateTimeFormat('uk-UA', { month: 'long', year: 'numeric' })
  .format(new Date());
---

<section class="s-explainer" id="explainer" aria-labelledby="explainer-h2">
  <div class="container">

    <div class="sect-rule">
      <span class="sect-no">01</span>
      <span class="sect-label">Регуляторний контекст</span>
    </div>

    <!-- AEO: definitional intro — designed to be quoted by AI answer engines -->
    <div class="sect-cols">
      <h2 id="explainer-h2" class="sect-h2">Що таке SAF-T UA?</h2>
      <p class="sect-lead">
        Формат і структура файлу визначені вимогами Міністерства фінансів
        та ДПС України. Нижче — визначення, регуляторні факти та роль
        SAF-T Connector у цьому процесі.
      </p>
    </div>

    <!-- Definition — editorial pull-quote treatment -->
    <p class="expl-def">
      <strong>SAF-T UA (Standard Audit File for Tax)</strong> — стандартний аудиторський
      файл для цілей оподаткування в Україні. Це XML-файл із визначеною структурою,
      який містить облікові дані, вивантажені з облікової системи за встановлений
      звітний період. Структура включає блоки <strong>Header</strong>,
      <strong>MasterFiles</strong> (зокрема TaxDifferences),
      <strong>GeneralLedgerEntries</strong> та <strong>SourceDocuments</strong>.
    </p>

    <!-- Two columns: context + connector -->
    <div class="expl-cols">

      <div class="expl-col">
        <div class="expl-col-head">
          <span class="expl-col-no">A</span>
          <h3 class="expl-col-h3">SAF-T UA в Україні</h3>
        </div>
        <p>
          Файл SAF-T UA подається <strong>великими платниками податків</strong> на запит
          контролюючого органу. Конкретні вимоги залежать від поточного законодавства,
          статусу платника та запитів ДПС. Файл має бути надано протягом
          <strong>2 робочих днів</strong> після отримання запиту.
        </p>
        <p>
          Файл охоплює: загальну книгу та облікові регістри, дебіторів і кредиторів,
          документи продажів і закупівель, платежі, необоротні та нематеріальні активи,
          рух товарів, податкові різниці та первинні документи.
        </p>
        <div class="expl-fact-row">
          <div class="expl-fact">
            <span class="expl-fact-val">2 дні</span>
            <span class="expl-fact-lbl">термін подання після запиту ДПС</span>
          </div>
          <div class="expl-fact">
            <span class="expl-fact-val">XML</span>
            <span class="expl-fact-lbl">формат на основі XSD-схеми ДПС</span>
          </div>
        </div>
      </div>

      <div class="expl-col">
        <div class="expl-col-head">
          <span class="expl-col-no">B</span>
          <h3 class="expl-col-h3">Що робить SAF-T Connector</h3>
        </div>
        <p>
          <strong>SAF-T Connector</strong> — програмне рішення LUCAS для формування аудиторського
          файлу SAF-T UA. Система зчитує дані з облікових систем та інших узгоджених джерел,
          трансформує їх відповідно до налаштованого мапінгу та генерує XML-файл.
        </p>
        <p>
          Поруч із XML формується Excel-представлення для зручної перевірки командою клієнта.
          Вбудована валідація перевіряє файл за офіційною схемою ДПС, виконує математичні та
          міжсекційні перевірки до подання.
        </p>
        <ul class="expl-list">
          <li>Налаштована інтеграція з обліковою системою клієнта</li>
          <li>Мапінг облікових даних на структуру звітного файлу</li>
          <li>XSD-валідація, математичні та міжсекційні перевірки</li>
          <li>Excel-перегляд аудиторського файлу поруч із XML</li>
        </ul>
      </div>
    </div>

    <!-- AEO reference table -->
    <div class="expl-table-wrap">
      <table class="expl-table" aria-label="Ключові характеристики SAF-T UA">
        <thead>
          <tr>
            <th scope="col">Характеристика</th>
            <th scope="col">Значення</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <th scope="row">Термін подання</th>
            <td>2 робочі дні після запиту контролюючого органу</td>
          </tr>
          <tr>
            <th scope="row">Формат</th>
            <td>XML (XSD-схема ДПС)</td>
          </tr>
          <tr>
            <th scope="row">Платники</th>
            <td>Великі платники податків (вимоги залежать від законодавства та запитів ДПС)</td>
          </tr>
          <tr>
            <th scope="row">Орган-регулятор</th>
            <td>ДПС України / Міністерство фінансів України</td>
          </tr>
          <tr>
            <th scope="row">Структура файлу</th>
            <td>Header, MasterFiles (TaxDifferences), GeneralLedgerEntries, SourceDocuments</td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Official sources + freshness signal -->
    <div class="expl-sources">
      <span class="expl-src-lbl">Офіційні джерела</span>
      <a href="https://mof.gov.ua" target="_blank" rel="noopener" class="expl-src-link">Міністерство фінансів України</a>
      <span class="expl-src-sep" aria-hidden="true">·</span>
      <a href="https://tax.gov.ua" target="_blank" rel="noopener" class="expl-src-link">Державна податкова служба України</a>
      <span class="expl-updated">Оновлено: {updatedLabel}</span>
    </div>

  </div>
</section>

<style>
/* Definition pull-quote */
.expl-def {
  position: relative;
  max-width: 62ch;
  padding-left: 28px;
  border-left: 2px solid var(--accent);
  font-family: var(--display);
  font-weight: 400;
  font-size: clamp(18px, 1.6vw, 23px);
  letter-spacing: -0.015em;
  line-height: 1.55;
  color: var(--ink-soft);
  margin-bottom: 88px;
}
.expl-def strong { color: var(--ink); font-weight: 600; }

/* Two columns, hairline-divided */
.expl-cols {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0 80px;
  margin-bottom: 88px;
  position: relative;
}
.expl-cols::before {
  content: "";
  position: absolute;
  top: 0; bottom: 0; left: 50%;
  width: 1px;
  background: var(--line);
}

.expl-col { display: flex; flex-direction: column; gap: 18px; min-width: 0; }

.expl-col-head {
  display: flex;
  align-items: baseline;
  gap: 14px;
  padding-top: 18px;
  border-top: 1px solid var(--line-strong);
  margin-bottom: 6px;
}
.expl-col-no {
  font-family: var(--mono);
  font-size: 12px;
  font-weight: 600;
  color: var(--accent-text);
}
.expl-col-h3 {
  font-family: var(--display);
  font-weight: 600;
  font-size: clamp(19px, 1.7vw, 24px);
  letter-spacing: -0.022em;
  line-height: 1.2;
  color: var(--ink);
}
.expl-col p {
  font-family: var(--body);
  font-size: 15px;
  line-height: 1.75;
  color: var(--ink-soft);
}
.expl-col p strong { color: var(--ink); font-weight: 600; }

.expl-list {
  list-style: none;
  padding: 0; margin: 6px 0 0;
  display: flex; flex-direction: column;
}
.expl-list li {
  position: relative;
  padding: 9px 0 9px 22px;
  border-top: 1px solid var(--line);
  font-family: var(--body);
  font-size: 14px;
  line-height: 1.55;
  color: var(--ink-soft);
}
.expl-list li::before {
  content: "";
  position: absolute; left: 2px; top: 17px;
  width: 8px; height: 1.5px;
  background: var(--accent);
}

/* Facts — financial-report style stat pair */
.expl-fact-row {
  display: flex;
  gap: 0;
  margin-top: 14px;
}
.expl-fact {
  display: flex;
  flex-direction: column;
  gap: 6px;
  padding: 18px 32px 0 0;
  border-top: 1px solid var(--line-strong);
  flex: 1;
}
.expl-fact + .expl-fact { padding-left: 32px; border-left: 1px solid var(--line); }
.expl-fact-val {
  font-family: var(--display);
  font-size: clamp(30px, 2.6vw, 42px);
  font-weight: 600;
  letter-spacing: -0.03em;
  color: var(--ink);
  line-height: 1;
}
.expl-fact-lbl {
  font-family: var(--mono);
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--ink-mute);
  max-width: 22ch;
  line-height: 1.5;
}

/* Reference table */
.expl-table-wrap { overflow-x: auto; }
.expl-table {
  width: 100%;
  border-collapse: collapse;
  font-family: var(--body);
  font-size: 15px;
  line-height: 1.6;
}
.expl-table thead th {
  text-align: left;
  font-family: var(--mono);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--ink-mute);
  padding: 0 24px 14px 0;
  border-bottom: 1px solid var(--line-strong);
}
.expl-table thead th:last-child { padding-right: 0; }
.expl-table th[scope="row"] {
  text-align: left;
  font-weight: 600;
  color: var(--ink);
  padding: 14px 24px 14px 0;
  border-bottom: 1px solid var(--line);
  white-space: nowrap;
  width: 280px;
  vertical-align: top;
  font-size: 14.5px;
}
.expl-table td {
  color: var(--ink-soft);
  padding: 14px 0;
  border-bottom: 1px solid var(--line);
  font-size: 14.5px;
}

/* Sources + freshness row */
.expl-sources {
  display: flex;
  align-items: baseline;
  gap: 14px;
  flex-wrap: wrap;
  margin-top: 28px;
  padding-top: 18px;
  border-top: 1px solid var(--line);
}
.expl-src-lbl {
  font-family: var(--mono);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--ink-mute);
}
.expl-src-link {
  font-family: var(--body);
  font-size: 13.5px;
  color: var(--ink-soft);
  text-decoration: underline;
  text-decoration-thickness: 1px;
  text-decoration-color: var(--line-strong);
  text-underline-offset: 3px;
  transition: color .2s var(--ease);
}
.expl-src-link:hover { color: var(--accent-text); }
.expl-src-link:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; border-radius: 2px; }
.expl-src-sep { color: var(--ink-mute); }
.expl-updated {
  margin-left: auto;
  font-family: var(--mono);
  font-size: 10.5px;
  letter-spacing: .06em;
  color: var(--ink-mute);
}

@media (max-width: 900px) {
  .expl-def { margin-bottom: 64px; }
  .expl-cols { grid-template-columns: 1fr; gap: 48px; margin-bottom: 64px; }
  .expl-cols::before { display: none; }
  .expl-fact-row { gap: 0; }
}
@media (max-width: 720px) {
  .expl-def { padding-left: 20px; }
  .expl-table th[scope="row"] { width: 150px; font-size: 13.5px; white-space: normal; }
  .expl-table td { font-size: 13.5px; }
  .expl-fact + .expl-fact { padding-left: 20px; }
  .expl-fact { padding-right: 20px; }
}
</style>
