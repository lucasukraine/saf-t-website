---
// SaftCta.astro — Final CTA section / contact
---

<section class="s-cta" id="contact" aria-labelledby="cta-h2">
  <div class="cta-glow" aria-hidden="true"></div>
  <div class="container">
    <div class="cta-inner">

      <div class="eyebrow orange">Наступний крок</div>

      <h2 id="cta-h2" class="cta-h2">
        Готові розпочати впровадження<br>
        <span class="cta-h2-accent">SAF-T Connector?</span>
      </h2>

      <p class="cta-lead">
        Розкажіть нам про вашу облікову систему. Ми проаналізуємо, чи достатньо
        наявних даних для SAF-T UA, та запропонуємо оптимальний підхід до впровадження.
      </p>

      <div class="cta-actions">
        <a href="mailto:info@lucasua.com" class="btn btn-orange">
          Запитати вартість <span class="btn-arrow" aria-hidden="true">→</span>
        </a>
        <a href="#faq" class="btn btn-ghost">
          Переглянути FAQ
        </a>
      </div>

      <div class="cta-contacts">
        <div class="cta-contact-item">
          <span class="cta-contact-lbl">Написати нам</span>
          <button type="button" class="cta-contact-val email-reveal" data-user="info" data-domain="lucasua.com">Показати email</button>
        </div>
        <div class="cta-contact-item">
          <span class="cta-contact-lbl">Зателефонувати</span>
          <a href="tel:+380443447915" class="cta-contact-val">+38 (044) 344-79-15</a>
        </div>
        <div class="cta-contact-item">
          <span class="cta-contact-lbl">Офіс</span>
          <span class="cta-contact-val is-static">Київ, БЦ Гулівер</span>
        </div>
        <div class="cta-contact-item">
          <span class="cta-contact-lbl">Компанія</span>
          <a href="https://www.lucasua.com" target="_blank" rel="noopener" class="cta-contact-val" aria-label="LUCAS — зовнішній сайт">lucasua.com</a>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
.s-cta {
  position: relative;
  overflow: hidden;
}
.cta-glow {
  position: absolute;
  top: -120px; left: 50%; transform: translateX(-50%);
  width: 980px; height: 460px;
  background: radial-gradient(ellipse, rgba(255,122,26,.10), transparent 65%);
  filter: blur(80px);
  pointer-events: none;
}

.cta-inner {
  max-width: 760px;
  margin: 0 auto;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 1;
}

.cta-inner .eyebrow {
  margin-bottom: 30px;
  color: var(--ink-mute);
}

.cta-h2 {
  font-family: var(--display);
  font-weight: 600;
  font-size: clamp(36px, 4vw, 62px);
  letter-spacing: -0.04em;
  line-height: 1.04;
  color: var(--ink);
  margin-bottom: 26px;
  text-wrap: balance;
}
.cta-h2-accent { color: var(--cta); }

.cta-lead {
  font-size: clamp(15.5px, 1.2vw, 17.5px);
  line-height: 1.7;
  color: var(--ink-soft);
  max-width: 52ch;
  margin-bottom: 44px;
}

.cta-actions {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  justify-content: center;
  margin-bottom: 72px;
}

/* Contacts — hairline editorial row */
.cta-contacts {
  display: flex;
  align-items: stretch;
  justify-content: center;
  gap: 0;
  flex-wrap: wrap;
  border-top: 1px solid var(--line);
  padding-top: 28px;
  width: 100%;
}
.cta-contact-item {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  text-align: left;
  gap: 6px;
  padding: 0 36px;
  border-left: 1px solid var(--line);
}
.cta-contact-item:first-child { border-left: none; }
.cta-contact-lbl {
  font-family: var(--mono);
  font-size: 9.5px;
  font-weight: 600;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--ink-mute);
}
.cta-contact-val {
  font-family: var(--body);
  font-size: 14px;
  font-weight: 500;
  color: var(--ink);
  text-decoration: none;
  transition: color .2s var(--ease);
}
a.cta-contact-val:hover,
button.cta-contact-val:hover { color: var(--accent-text); }
.cta-contact-val:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; border-radius: 2px; }
.cta-contact-val.is-static { color: var(--ink-soft); }

/* email-reveal inherits .cta-contact-val look; hover handled above */
.cta-contact-item button.email-reveal:hover { color: var(--accent-text); }

@media (max-width: 900px) {
  .cta-contacts {
    flex-direction: column;
    gap: 20px;
    align-items: center;
  }
  .cta-contact-item {
    border-left: none;
    padding: 0;
    align-items: center;
    text-align: center;
  }
}
@media (max-width: 720px) {
  .cta-actions { flex-direction: column; width: 100%; max-width: 340px; }
  .cta-actions .btn { justify-content: center; }
  .cta-inner .eyebrow { margin-bottom: 22px; }
}
</style>
