---
// SaftCta.astro — Final CTA section / contact
---

<section class="s-cta" id="contact" aria-labelledby="cta-h2">
  <div class="container">
    <div class="cta-inner">

      <div class="eyebrow orange">Наступний крок</div>

      <h2 id="cta-h2" class="cta-h2">
        Готові розпочати впровадження<br>
        <span class="cta-h2-accent">SAF-T Connector?</span>
      </h2>

      <p class="cta-lead">
        Розкажіть нам про вашу облікову систему. Ми проаналізуємо, чи достатньо
        наявних даних для SAF-T UA, та запропонуємо оптимальний підхід до впровадження.
      </p>

      <div class="cta-actions">
        <a href="mailto:info@lucasua.com" class="btn btn-orange">
          Обговорити впровадження <span class="btn-arrow" aria-hidden="true">→</span>
        </a>
        <a href="#faq" class="btn btn-ghost-light">
          Переглянути FAQ
        </a>
      </div>

      <div class="cta-contacts">
        <div class="cta-contact-item">
          <span class="cta-contact-lbl">Написати нам</span>
          <a href="mailto:info@lucasua.com" class="cta-contact-val">info@lucasua.com</a>
        </div>
        <span class="cta-sep" aria-hidden="true">·</span>
        <div class="cta-contact-item">
          <span class="cta-contact-lbl">Зателефонувати</span>
          <a href="tel:+380443447915" class="cta-contact-val">+38 (044) 344-79-15</a>
        </div>
      </div>

      <div class="cta-meta">
        <span>Київ, БЦ Гулівер</span>
        <span class="cta-sep" aria-hidden="true">·</span>
        <a href="https://www.lucasua.com" target="_blank" rel="noopener" aria-label="LUCAS — зовнішній сайт">LUCAS</a>
      </div>

    </div>
  </div>
</section>

<style>
.s-cta {
  background: var(--dark);
  color: var(--on-dark);
  padding: var(--section-py) 0;
  position: relative;
  border-top: 1px solid rgba(255,255,255,.06);
  overflow: hidden;
}
.s-cta::before {
  content: "";
  position: absolute;
  top: -100px; left: 50%; transform: translateX(-50%);
  width: 900px; height: 400px;
  background: radial-gradient(ellipse, rgba(3,169,244,.18), transparent 65%);
  filter: blur(80px);
  pointer-events: none;
}

.cta-inner {
  max-width: 700px;
  margin: 0 auto;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
  position: relative;
  z-index: 1;
}

.cta-inner .eyebrow {
  margin-bottom: 28px;
  justify-content: center;
  color: rgba(238,242,255,.60);
}
.cta-inner .eyebrow::before { background: var(--orange); }

.cta-h2 {
  font-family: var(--display);
  font-weight: 500;
  font-size: clamp(34px, 3.6vw, 58px);
  letter-spacing: -0.04em;
  line-height: 1.06;
  color: #fff;
  margin-bottom: 24px;
}
.cta-h2-accent { color: var(--orange); }

.cta-lead {
  font-size: clamp(16px, 1.2vw, 18px);
  line-height: 1.65;
  color: var(--on-dark-soft);
  max-width: 52ch;
  margin-bottom: 40px;
}

.cta-actions {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  justify-content: center;
  margin-bottom: 32px;
}

.btn-ghost-light {
  background: rgba(255,255,255,.08);
  color: rgba(238,242,255,.80);
  border-color: rgba(255,255,255,.18);
}
.btn-ghost-light:hover {
  background: rgba(255,255,255,.14);
  color: #fff;
}
.btn-ghost-light:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }

.cta-contacts {
  display: flex;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
  justify-content: center;
  margin-bottom: 16px;
}
.cta-contact-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 3px;
}
.cta-contact-lbl {
  font-family: var(--mono);
  font-size: 9.5px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(238,242,255,.55);
}
.cta-contact-val {
  font-family: var(--mono);
  font-size: 12px;
  font-weight: 600;
  color: rgba(238,242,255,.70);
  text-decoration: none;
  transition: color .2s var(--ease);
}
.cta-contact-val:hover { color: #fff; }
.cta-contact-val:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; border-radius: 2px; }

.cta-meta {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
  justify-content: center;
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.06em;
  color: rgba(238,242,255,.50);
}
.cta-meta a { color: rgba(238,242,255,.60); text-decoration: none; transition: color .2s var(--ease); }
.cta-meta a:hover { color: #fff; }
.cta-meta a:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; border-radius: 2px; }
.cta-sep { color: rgba(238,242,255,.20); }

@media (max-width: 720px) {
  .cta-actions { flex-direction: column; width: 100%; max-width: 340px; }
  .cta-actions .btn { justify-content: center; }
  .cta-contacts { gap: 12px; }
  .cta-meta { font-size: 10px; }
}
</style>
