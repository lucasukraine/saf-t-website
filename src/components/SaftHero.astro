---
// SaftHero.astro — Hero section with HTML/CSS product mockup
---

<section class="s-hero" aria-labelledby="hero-h1">

  <!-- Atmospheric background: fine grid + single soft glow -->
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-glow"></div>
    <div class="hero-grid-lines"></div>
  </div>

  <div class="container hero-layout">

    <!-- Left: text content -->
    <div class="hero-text">
      <div class="eyebrow ha d1">Програмне рішення LUCAS</div>

      <!-- H1 is the LCP element — rendered without entrance animation -->
      <h1 id="hero-h1" class="hero-h1">
        SAF-T Connector —
        <span class="hero-h1-accent">підготовка SAF-T UA</span>
        з ваших облікових даних
      </h1>

      <p class="hero-lead ha d3">
        Рішення витягує дані з ERP, перевіряє їх структуру та формує файл для подання
        до ДПС відповідно до українських вимог е-аудиту.
      </p>

      <div class="hero-actions ha d4">
        <a href="#contact" class="btn btn-orange">
          Запитати вартість <span class="btn-arrow" aria-hidden="true">→</span>
        </a>
        <a href="#how-it-works" class="btn btn-ghost">
          Як це працює
        </a>
      </div>

      <div class="hero-signals ha d5" aria-label="Підтримувані системи">
        <span class="signal-label">Інтеграція</span>
        <span class="signal-line">SAP · BAS / 1C · Odoo · Oracle · MS Dynamics · Excel / CSV · Будь-які інші, у тому числі кастомні облікові системи</span>
      </div>
    </div>

    <!-- Right: HTML/CSS product UI mockup -->
    <div class="hero-mockup-wrap ha d3" aria-hidden="true">
      <div class="mockup-card">

        <!-- Window chrome -->
        <div class="mc-bar">
          <span class="mc-title">SAF-T Connector</span>
          <span class="mc-badge"><span class="mc-status-dot pulse"></span>Обробка</span>
        </div>

        <!-- File row -->
        <div class="mc-status-row">
          <span class="mc-status-text">SAF-T UA_2024_Q4.xml</span>
          <span class="mc-status-meta">формування</span>
        </div>

        <!-- Two-column panel -->
        <div class="mc-panels">

          <!-- Sources panel -->
          <div class="mc-panel">
            <div class="mc-panel-label">Джерело · SAP ERP</div>
            <div class="mc-rows">
              <div class="mc-row done">
                <span class="mc-icon ok">✓</span>
                <span class="mc-row-name">Рахунки (COA)</span>
                <span class="mc-row-meta ok-text">OK</span>
              </div>
              <div class="mc-row done">
                <span class="mc-icon ok">✓</span>
                <span class="mc-row-name">Субрахунки</span>
                <span class="mc-row-meta ok-text">OK</span>
              </div>
              <div class="mc-row done">
                <span class="mc-icon ok">✓</span>
                <span class="mc-row-name">Журнал проводок</span>
                <span class="mc-row-meta ok-text">OK</span>
              </div>
              <div class="mc-row active">
                <span class="mc-icon spin">⟳</span>
                <span class="mc-row-name">Реєстр ПДВ</span>
                <span class="mc-row-meta">···</span>
              </div>
              <div class="mc-row dim">
                <span class="mc-icon pend">○</span>
                <span class="mc-row-name">Необоротні активи</span>
                <span class="mc-row-meta">—</span>
              </div>
            </div>
          </div>

          <!-- Validation panel -->
          <div class="mc-panel mc-panel-right">
            <div class="mc-panel-label">XSD-валідація</div>
            <div class="mc-rows">
              <div class="mc-row done">
                <span class="mc-icon ok">✓</span>
                <span class="mc-row-name">Структура файлу</span>
                <span class="mc-row-meta ok-text">OK</span>
              </div>
              <div class="mc-row done">
                <span class="mc-icon ok">✓</span>
                <span class="mc-row-name">Формати дат</span>
                <span class="mc-row-meta ok-text">OK</span>
              </div>
              <div class="mc-row done">
                <span class="mc-icon ok">✓</span>
                <span class="mc-row-name">Коди рахунків</span>
                <span class="mc-row-meta ok-text">OK</span>
              </div>
              <div class="mc-row done">
                <span class="mc-icon ok">✓</span>
                <span class="mc-row-name">ЄДРПОУ</span>
                <span class="mc-row-meta ok-text">OK</span>
              </div>
              <div class="mc-row active">
                <span class="mc-icon spin">⟳</span>
                <span class="mc-row-name">Суми транзакцій</span>
                <span class="mc-row-meta">···</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Progress bar -->
        <div class="mc-progress-wrap">
          <div class="mc-progress-bar">
            <div class="mc-progress-fill" style="width: 60%"></div>
          </div>
          <div class="mc-progress-meta">
            <span>60% — генерація XML</span>
            <span class="mc-progress-num">3 / 5 модулів</span>
          </div>
        </div>

        <!-- XML snippet -->
        <div class="mc-xml">
          <div class="mc-xml-label">Попередній перегляд</div>
          <div class="mc-xml-code">
            <span class="xl-ln"><span class="xl-t">&lt;</span><span class="xl-e">SAFTFile</span><span class="xl-t">&gt;</span></span>
            <span class="xl-ln xl-i1"><span class="xl-t">&lt;</span><span class="xl-e">Header</span><span class="xl-t">&gt;</span></span>
            <span class="xl-ln xl-i2"><span class="xl-t">&lt;</span><span class="xl-e">AuditFileVersion</span><span class="xl-t">&gt;</span><span class="xl-v">···</span><span class="xl-t">&lt;/</span><span class="xl-e">AuditFileVersion</span><span class="xl-t">&gt;</span></span>
            <span class="xl-ln xl-i2"><span class="xl-t">&lt;</span><span class="xl-e">TaxRegistrationNumber</span><span class="xl-t">&gt;</span><span class="xl-v">ЄДРПОУ</span><span class="xl-t">&lt;/</span><span class="xl-e">TaxRegistrationNumber</span><span class="xl-t">&gt;</span></span>
            <span class="xl-ln xl-i2"><span class="xl-t">&lt;</span><span class="xl-e">FiscalYear</span><span class="xl-t">&gt;</span><span class="xl-v">2024</span><span class="xl-t">&lt;/</span><span class="xl-e">FiscalYear</span><span class="xl-t">&gt;</span></span>
            <span class="xl-ln xl-i1"><span class="xl-t">&lt;/</span><span class="xl-e">Header</span><span class="xl-t">&gt;</span></span>
            <span class="xl-ln xl-dim"><span class="xl-t">&lt;</span><span class="xl-e">MasterFiles</span><span class="xl-t">&gt;</span> <span class="xl-c">···</span></span>
          </div>
        </div>
      </div>

      <!-- Floating badge -->
      <div class="mockup-badge">
        <span class="badge-dot"></span>
        Згідно вимог ДПС
      </div>
    </div>
  </div>

</section>

<style>
.s-hero {
  position: relative;
  color: var(--ink);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  isolation: isolate;
  padding: 0;
}

/* Atmospheric background */
.hero-bg {
  position: absolute;
  inset: 0;
  z-index: 0;
  pointer-events: none;
}
.hero-glow {
  position: absolute;
  width: 1100px; height: 720px;
  top: -280px; left: -180px;
  background: radial-gradient(ellipse, rgba(3,169,244,.13), transparent 68%);
  filter: blur(70px);
}
.hero-grid-lines {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(to right, rgba(160,190,235,.045) 1px, transparent 1px),
    linear-gradient(to bottom, rgba(160,190,235,.045) 1px, transparent 1px);
  background-size: 80px 80px;
  -webkit-mask-image: radial-gradient(ellipse 85% 75% at 45% 38%, #000 15%, transparent 92%);
          mask-image: radial-gradient(ellipse 85% 75% at 45% 38%, #000 15%, transparent 92%);
}

/* Layout grid */
.hero-layout {
  position: relative;
  z-index: 2;
  flex: 1;
  display: grid;
  grid-template-columns: 1.04fr .96fr;
  gap: 72px;
  align-items: center;
  padding-top: 128px;
  padding-bottom: 96px;
}

/* Text column */
.hero-text { display: flex; flex-direction: column; }

.hero-h1 {
  margin-top: 30px;
  font-family: var(--display);
  font-weight: 600;
  font-size: clamp(40px, 4vw, 66px);
  letter-spacing: -0.038em;
  line-height: 1.03;
  color: var(--ink);
}
.hero-h1-accent {
  color: var(--accent-text);
  display: block;
}

.hero-lead {
  margin-top: 30px;
  font-size: clamp(16px, 1.2vw, 18.5px);
  line-height: 1.65;
  color: var(--ink-soft);
  max-width: 50ch;
  font-weight: 400;
}

.hero-actions {
  margin-top: 44px;
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}

/* Integration line — hairline editorial row */
.hero-signals {
  margin-top: 52px;
  padding-top: 18px;
  border-top: 1px solid var(--line);
  display: flex;
  align-items: baseline;
  gap: 20px;
  max-width: 560px;
}
.signal-label {
  font-family: var(--mono);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--ink-mute);
  flex: none;
}
.signal-line {
  font-family: var(--mono);
  font-size: 11.5px;
  line-height: 1.9;
  letter-spacing: .02em;
  color: var(--ink-soft);
}

/* Entrance animations */
.ha {
  opacity: 0;
  transform: translateY(20px);
  animation: haIn .85s var(--ease) forwards;
}
.ha.d1 { animation-delay: .05s; }
.ha.d3 { animation-delay: .18s; }
.ha.d4 { animation-delay: .34s; }
.ha.d5 { animation-delay: .50s; }

@keyframes haIn { to { opacity: 1; transform: translateY(0); } }

/* =============================================================
   PRODUCT MOCKUP — dark chrome in both themes
   ============================================================= */
.hero-mockup-wrap {
  position: relative;
  perspective: 1600px;
}

.mockup-card {
  background: var(--chrome);
  border: 1px solid var(--chrome-line);
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow:
    0 1px 0 rgba(255,255,255,.05) inset,
    0 24px 64px -16px rgba(2,4,10,.55),
    0 4px 16px rgba(2,4,10,.30);
  transform: rotateY(-4deg) rotateX(1.5deg);
  transition: transform .5s var(--ease);
}
.hero-mockup-wrap:hover .mockup-card {
  transform: rotateY(-1deg) rotateX(.5deg);
}

/* Window bar */
.mc-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  padding: 11px 16px;
  background: rgba(255,255,255,.025);
  border-bottom: 1px solid var(--chrome-line);
}
.mc-title {
  font-family: var(--mono);
  font-size: 10.5px;
  font-weight: 600;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: rgba(226,235,250,.55);
}
.mc-badge {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-family: var(--mono);
  font-size: 9.5px;
  font-weight: 600;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--accent-hi);
  background: rgba(3,169,244,.10);
  border: 1px solid rgba(3,169,244,.22);
  border-radius: 5px;
  padding: 3px 9px;
  white-space: nowrap;
}
.mc-status-dot {
  width: 5px; height: 5px;
  border-radius: 50%;
  background: var(--accent-hi);
  flex: none;
}
.mc-status-dot.pulse { animation: pulseDot 1.8s ease-in-out infinite; }

/* File row */
.mc-status-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  padding: 9px 16px;
  border-bottom: 1px solid var(--chrome-line);
}
.mc-status-text {
  font-family: var(--mono);
  font-size: 11px;
  font-weight: 500;
  color: rgba(226,235,250,.78);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.mc-status-meta {
  font-family: var(--mono);
  font-size: 9.5px;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: rgba(226,235,250,.32);
}

/* Two-column panels */
.mc-panels {
  display: grid;
  grid-template-columns: 1fr 1fr;
}
.mc-panel { padding: 13px 16px; }
.mc-panel-right { border-left: 1px solid var(--chrome-line); }
.mc-panel-label {
  font-family: var(--mono);
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(226,235,250,.32);
  margin-bottom: 11px;
}
.mc-rows { display: flex; flex-direction: column; gap: 8px; }
.mc-row {
  display: grid;
  grid-template-columns: 14px 1fr auto;
  gap: 8px;
  align-items: center;
}
.mc-row.dim { opacity: .38; }
.mc-icon {
  font-size: 10px;
  font-weight: 700;
  text-align: center;
  line-height: 1;
}
.mc-icon.ok { color: var(--ok); }
.mc-icon.spin {
  color: var(--accent-hi);
  display: inline-block;
  animation: spin .9s linear infinite;
}
.mc-icon.pend { color: rgba(226,235,250,.25); }
.mc-row-name {
  font-family: var(--body);
  font-size: 11.5px;
  color: rgba(226,235,250,.74);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.mc-row-meta {
  font-family: var(--mono);
  font-size: 10px;
  color: rgba(226,235,250,.36);
  text-align: right;
  white-space: nowrap;
}
.mc-row-meta.ok-text { color: var(--ok); }

/* Progress */
.mc-progress-wrap {
  padding: 12px 16px 9px;
  border-top: 1px solid var(--chrome-line);
}
.mc-progress-bar {
  height: 3px;
  background: rgba(226,235,250,.10);
  border-radius: 2px;
  overflow: hidden;
  margin-bottom: 7px;
}
.mc-progress-fill {
  height: 100%;
  background: var(--accent);
  border-radius: 2px;
  animation: progressGrow 2s ease-out forwards;
}
.mc-progress-meta {
  display: flex;
  justify-content: space-between;
  font-family: var(--mono);
  font-size: 9.5px;
  letter-spacing: .04em;
  color: rgba(226,235,250,.42);
}
.mc-progress-num { color: rgba(226,235,250,.30); }

/* XML snippet */
.mc-xml {
  padding: 11px 16px 14px;
  border-top: 1px solid var(--chrome-line);
}
.mc-xml-label {
  font-family: var(--mono);
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(226,235,250,.28);
  margin-bottom: 7px;
}
.mc-xml-code {
  background: rgba(2,4,10,.45);
  border: 1px solid rgba(160,185,225,.08);
  border-radius: 7px;
  padding: 9px 12px;
  display: flex;
  flex-direction: column;
  gap: 1px;
}
.xl-ln {
  display: block;
  font-family: var(--mono);
  font-size: 10.5px;
  line-height: 1.75;
  white-space: nowrap;
}
.xl-i1 { padding-left: 14px; }
.xl-i2 { padding-left: 28px; }
.xl-t { color: rgba(226,235,250,.34); }
.xl-e { color: #7cc7ff; }
.xl-v { color: #8fe6b4; }
.xl-c { color: rgba(226,235,250,.25); }
.xl-dim { opacity: .45; }

/* Floating badge */
.mockup-badge {
  position: absolute;
  bottom: -16px;
  right: -10px;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 9px 15px;
  background: var(--chrome);
  border: 1px solid var(--chrome-line);
  border-radius: var(--radius-sm);
  font-family: var(--mono);
  font-size: 10.5px;
  font-weight: 600;
  letter-spacing: 0.06em;
  color: rgba(226,235,250,.72);
  box-shadow: 0 10px 32px -8px rgba(2,4,10,.55);
}
.badge-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--ok);
  box-shadow: 0 0 0 3px rgba(52,209,120,.18);
  flex: none;
}

/* Animations */
@keyframes pulseDot {
  0%, 100% { box-shadow: 0 0 0 3px rgba(3,169,244,.20); }
  50%       { box-shadow: 0 0 0 5px rgba(3,169,244,.06); }
}
@keyframes progressGrow { from { width: 0; } }

/* =============================================================
   RESPONSIVE
   ============================================================= */
@media (max-width: 1080px) {
  .s-hero { min-height: 100svh; }
  .hero-layout {
    grid-template-columns: 1fr;
    padding-top: 108px;
    padding-bottom: 64px;
  }
  .hero-mockup-wrap { display: none; }
  .hero-h1 { font-size: clamp(38px, 6.4vw, 56px); }
  .hero-lead { max-width: 58ch; }
}

@media (max-width: 720px) {
  .s-hero { min-height: 100svh; }
  .hero-layout {
    padding-top: 92px;
    padding-bottom: 52px;
    gap: 0;
  }
  .hero-h1 {
    font-size: clamp(34px, 9vw, 46px);
    line-height: 1.05;
  }
  .hero-actions { margin-top: 36px; flex-direction: column; }
  .hero-actions .btn { width: 100%; justify-content: center; }
  .hero-signals { margin-top: 40px; flex-direction: column; gap: 8px; }
  .ha { animation-duration: .5s; }
  .ha.d1 { animation-delay: 0s; }
  .ha.d3 { animation-delay: .1s; }
  .ha.d4 { animation-delay: .18s; }
  .ha.d5 { animation-delay: .28s; }
}

@media (prefers-reduced-motion: reduce) {
  .ha { animation: none; opacity: 1; transform: none; }
  .mc-status-dot { animation: none; }
  .mc-icon.spin { animation: none; }
  .mc-progress-fill { animation: none; }
}
</style>
