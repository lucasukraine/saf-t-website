---
// SaftHero.astro — Hero section with HTML/CSS product mockup
---

<section class="s-hero" aria-labelledby="hero-h1">

  <!-- Atmospheric background -->
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-blob b1"></div>
    <div class="hero-blob b2"></div>
    <div class="hero-blob b3"></div>
    <div class="hero-grid-lines"></div>
  </div>

  <div class="container hero-layout">

    <!-- Left: text content -->
    <div class="hero-text">
      <div class="eyebrow on-dark ha d1">Програмне рішення для SAF-T UA</div>

      <h1 id="hero-h1" class="hero-h1 ha d2">
        SAF-T Connector —
        <span class="hero-h1-accent">формування та валідація</span>
        файлів SAF-T
      </h1>

      <p class="hero-lead ha d3">
        Автоматично витягує облікові дані з SAP, BAS/1C, Oracle, Microsoft Dynamics,
        Odoo та інших ERP-систем, перевіряє структуру XML за XSD-схемою ДПС
        та формує готовий файл SAF-T UA.
      </p>

      <div class="hero-actions ha d4">
        <a href="#contact" class="btn btn-orange">
          Замовити демо <span class="btn-arrow" aria-hidden="true">→</span>
        </a>
        <a href="#explainer" class="btn btn-ghost">
          Що таке SAF-T
        </a>
      </div>

      <div class="hero-signals ha d5" aria-label="Підтримувані системи">
        <span class="signal-label">Підтримка:</span>
        <span class="signal-tag">SAP ERP</span>
        <span class="signal-sep" aria-hidden="true">·</span>
        <span class="signal-tag">BAS / 1C</span>
        <span class="signal-sep" aria-hidden="true">·</span>
        <span class="signal-tag">Oracle</span>
        <span class="signal-sep" aria-hidden="true">·</span>
        <span class="signal-tag">MS Dynamics</span>
        <span class="signal-sep" aria-hidden="true">·</span>
        <span class="signal-tag">Odoo</span>
        <span class="signal-sep" aria-hidden="true">·</span>
        <span class="signal-tag">та інші</span>
      </div>
    </div>

    <!-- Right: HTML/CSS product UI mockup -->
    <div class="hero-mockup-wrap ha d3" aria-hidden="true">
      <div class="mockup-card">

        <!-- Window chrome -->
        <div class="mc-bar">
          <div class="mc-dots">
            <span class="mc-dot" style="background:#ff5f57"></span>
            <span class="mc-dot" style="background:#ffbd2e"></span>
            <span class="mc-dot" style="background:#28c840"></span>
          </div>
          <span class="mc-title">SAF-T Connector</span>
        </div>

        <!-- Status row -->
        <div class="mc-status-row">
          <span class="mc-status-dot pulse"></span>
          <span class="mc-status-text">Формування SAF-T UA_2024_Q4.xml</span>
          <span class="mc-badge">ОБРОБКА</span>
        </div>

        <!-- Two-column panel -->
        <div class="mc-panels">

          <!-- Sources panel -->
          <div class="mc-panel">
            <div class="mc-panel-label">Джерело: SAP ERP</div>
            <div class="mc-rows">
              <div class="mc-row done">
                <span class="mc-icon ok">✓</span>
                <span class="mc-row-name">Рахунки (COA)</span>
                <span class="mc-row-meta ok-text">OK</span>
              </div>
              <div class="mc-row done">
                <span class="mc-icon ok">✓</span>
                <span class="mc-row-name">Субрахунки</span>
                <span class="mc-row-meta ok-text">OK</span>
              </div>
              <div class="mc-row done">
                <span class="mc-icon ok">✓</span>
                <span class="mc-row-name">Журнал проводок</span>
                <span class="mc-row-meta ok-text">OK</span>
              </div>
              <div class="mc-row active">
                <span class="mc-icon spin">⟳</span>
                <span class="mc-row-name">Реєстр ПДВ</span>
                <span class="mc-row-meta">...</span>
              </div>
              <div class="mc-row dim">
                <span class="mc-icon pend">○</span>
                <span class="mc-row-name">Необоротні активи</span>
                <span class="mc-row-meta">—</span>
              </div>
            </div>
          </div>

          <!-- Validation panel -->
          <div class="mc-panel mc-panel-right">
            <div class="mc-panel-label">XSD-валідація</div>
            <div class="mc-rows">
              <div class="mc-row done">
                <span class="mc-icon ok">✓</span>
                <span class="mc-row-name">Структура файлу</span>
                <span class="mc-row-meta ok-text">OK</span>
              </div>
              <div class="mc-row done">
                <span class="mc-icon ok">✓</span>
                <span class="mc-row-name">Формати дат</span>
                <span class="mc-row-meta ok-text">OK</span>
              </div>
              <div class="mc-row done">
                <span class="mc-icon ok">✓</span>
                <span class="mc-row-name">Коди рахунків</span>
                <span class="mc-row-meta ok-text">OK</span>
              </div>
              <div class="mc-row done">
                <span class="mc-icon ok">✓</span>
                <span class="mc-row-name">ЄДРПОУ</span>
                <span class="mc-row-meta ok-text">OK</span>
              </div>
              <div class="mc-row active">
                <span class="mc-icon spin">⟳</span>
                <span class="mc-row-name">Суми транзакцій</span>
                <span class="mc-row-meta">...</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Progress bar -->
        <div class="mc-progress-wrap">
          <div class="mc-progress-bar">
            <div class="mc-progress-fill" style="width: 68%"></div>
          </div>
          <div class="mc-progress-meta">
            <span>68% — генерація XML</span>
            <span class="mc-progress-num">3 / 5 модулів</span>
          </div>
        </div>

        <!-- XML snippet -->
        <div class="mc-xml">
          <div class="mc-xml-label">Попередній перегляд</div>
          <div class="mc-xml-code">
            <span class="xl-ln"><span class="xl-t">&lt;</span><span class="xl-e">SAFTFile</span><span class="xl-t">&gt;</span></span>
            <span class="xl-ln xl-i1"><span class="xl-t">&lt;</span><span class="xl-e">Header</span><span class="xl-t">&gt;</span></span>
            <span class="xl-ln xl-i2"><span class="xl-t">&lt;</span><span class="xl-e">AuditFileVersion</span><span class="xl-t">&gt;</span><span class="xl-v">···</span><span class="xl-t">&lt;/</span><span class="xl-e">AuditFileVersion</span><span class="xl-t">&gt;</span></span>
            <span class="xl-ln xl-i2"><span class="xl-t">&lt;</span><span class="xl-e">TaxEntity</span><span class="xl-t">&gt;</span><span class="xl-v">ЄДРПОУ</span><span class="xl-t">&lt;/</span><span class="xl-e">TaxEntity</span><span class="xl-t">&gt;</span></span>
            <span class="xl-ln xl-i2"><span class="xl-t">&lt;</span><span class="xl-e">FiscalYear</span><span class="xl-t">&gt;</span><span class="xl-v">2024</span><span class="xl-t">&lt;/</span><span class="xl-e">FiscalYear</span><span class="xl-t">&gt;</span></span>
            <span class="xl-ln xl-i1"><span class="xl-t">&lt;/</span><span class="xl-e">Header</span><span class="xl-t">&gt;</span></span>
            <span class="xl-ln xl-dim"><span class="xl-t">&lt;</span><span class="xl-e">MasterFiles</span><span class="xl-t">&gt;</span> <span class="xl-c">···</span></span>
          </div>
        </div>
      </div>

      <!-- Floating badge -->
      <div class="mockup-badge">
        <span class="badge-dot"></span>
        Сумісно з ДПС UA
      </div>
    </div>
  </div>

  <!-- Bottom fade -->
  <div class="hero-fade" aria-hidden="true"></div>
</section>

<style>
.s-hero {
  position: relative;
  background: var(--dark);
  color: var(--on-dark);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  isolation: isolate;
}

/* Atmospheric background */
.hero-bg {
  position: absolute;
  inset: 0;
  z-index: 0;
  pointer-events: none;
}
.hero-blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  opacity: 1;
}
.hero-blob.b1 {
  width: 700px; height: 500px;
  top: -10%; left: -5%;
  background: radial-gradient(ellipse, rgba(3,169,244,.26), transparent 70%);
  animation: blobDrift 28s ease-in-out infinite alternate;
}
.hero-blob.b2 {
  width: 600px; height: 500px;
  top: 10%; right: -8%;
  background: radial-gradient(ellipse, rgba(3,169,244,.15), transparent 70%);
  animation: blobDrift 34s ease-in-out infinite alternate-reverse;
}
.hero-blob.b3 {
  width: 400px; height: 300px;
  bottom: 5%; left: 40%;
  background: radial-gradient(ellipse, rgba(255,152,0,.10), transparent 70%);
  animation: blobDrift 22s ease-in-out infinite alternate;
}
.hero-grid-lines {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(to right, rgba(255,255,255,.028) 1px, transparent 1px),
    linear-gradient(to bottom, rgba(255,255,255,.028) 1px, transparent 1px);
  background-size: 72px 72px;
  -webkit-mask-image: radial-gradient(ellipse 90% 80% at 50% 40%, #000 20%, transparent 90%);
          mask-image: radial-gradient(ellipse 90% 80% at 50% 40%, #000 20%, transparent 90%);
}

/* Layout grid */
.hero-layout {
  position: relative;
  z-index: 2;
  flex: 1;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: center;
  padding-top: 120px;
  padding-bottom: 80px;
}

/* Text column */
.hero-text {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.hero-h1 {
  margin-top: 26px;
  font-family: var(--display);
  font-weight: 500;
  font-size: clamp(38px, 3.8vw, 62px);
  letter-spacing: -0.035em;
  line-height: 1.06;
  color: #fff;
}
.hero-h1-accent {
  color: var(--accent-light);
  display: block;
}

.hero-lead {
  margin-top: 28px;
  font-size: clamp(16px, 1.2vw, 19px);
  line-height: 1.6;
  color: var(--on-dark-soft);
  max-width: 52ch;
  font-weight: 400;
}

.hero-actions {
  margin-top: 40px;
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}

.hero-signals {
  margin-top: 36px;
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
  font-size: 12.5px;
  font-weight: 500;
  color: var(--on-dark-mute);
}
.signal-label { letter-spacing: 0.02em; }
.signal-tag {
  font-family: var(--mono);
  font-size: 11px;
  color: rgba(238,242,255,.55);
  background: rgba(255,255,255,.06);
  border: 1px solid rgba(255,255,255,.08);
  border-radius: 4px;
  padding: 2px 7px;
}
.signal-sep { color: rgba(255,255,255,.20); }

/* Entrance animations */
.ha {
  opacity: 0;
  transform: translateY(22px);
  animation: haIn .9s var(--ease) forwards;
}
.ha.d1 { animation-delay: .05s; }
.ha.d2 { animation-delay: .18s; }
.ha.d3 { animation-delay: .32s; }
.ha.d4 { animation-delay: .50s; }
.ha.d5 { animation-delay: .68s; }

@keyframes haIn { to { opacity: 1; transform: translateY(0); } }
@keyframes blobDrift {
  0%   { transform: translate(0, 0) scale(1); }
  100% { transform: translate(3%, 2%) scale(1.06); }
}

/* =============================================================
   PRODUCT MOCKUP
   ============================================================= */
.hero-mockup-wrap {
  position: relative;
  perspective: 1400px;
}

.mockup-card {
  background: var(--glass-dark);
  backdrop-filter: blur(32px) saturate(1.4);
  -webkit-backdrop-filter: blur(32px) saturate(1.4);
  border: 1px solid var(--glass-dark-border);
  border-radius: 14px;
  overflow: hidden;
  box-shadow:
    var(--glass-dark-shadow),
    0 0 0 1px rgba(3,169,244,.12),
    0 40px 80px -20px rgba(0,0,0,.6);
  transform: rotateY(-6deg) rotateX(2deg);
  transition: transform .4s var(--ease);
}
.hero-mockup-wrap:hover .mockup-card {
  transform: rotateY(-2deg) rotateX(1deg);
}

/* Window bar */
.mc-bar {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 14px;
  background: rgba(0,0,0,.25);
  border-bottom: 1px solid rgba(255,255,255,.06);
}
.mc-dots { display: flex; gap: 5px; }
.mc-dot { width: 10px; height: 10px; border-radius: 50%; }
.mc-title {
  font-family: var(--mono);
  font-size: 11px;
  font-weight: 600;
  color: rgba(238,242,255,.50);
  flex: 1;
  text-align: center;
  letter-spacing: 0.04em;
}
.mc-version {
  font-family: var(--mono);
  font-size: 10px;
  color: rgba(238,242,255,.28);
  letter-spacing: 0.06em;
}

/* Status row */
.mc-status-row {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 14px;
  background: rgba(3,169,244,.08);
  border-bottom: 1px solid rgba(255,255,255,.05);
}
.mc-status-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: #0288d1;
  flex: none;
}
.mc-status-dot.pulse { animation: pulseDot 1.8s ease-in-out infinite; }
.mc-status-text {
  font-family: var(--mono);
  font-size: 10.5px;
  color: rgba(238,242,255,.60);
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.mc-badge {
  font-family: var(--mono);
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.14em;
  color: #29b6f6;
  background: rgba(3,169,244,.12);
  border: 1px solid rgba(3,169,244,.22);
  border-radius: 4px;
  padding: 2px 6px;
  white-space: nowrap;
}

/* Two-column panels */
.mc-panels {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
  padding: 0;
}
.mc-panel {
  padding: 12px 14px;
}
.mc-panel-right {
  border-left: 1px solid rgba(255,255,255,.05);
}
.mc-panel-label {
  font-family: var(--mono);
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(238,242,255,.30);
  margin-bottom: 10px;
}
.mc-rows { display: flex; flex-direction: column; gap: 7px; }
.mc-row {
  display: grid;
  grid-template-columns: 14px 1fr auto;
  gap: 7px;
  align-items: center;
  font-size: 11.5px;
}
.mc-row.dim { opacity: .40; }
.mc-icon {
  font-size: 10px;
  font-weight: 700;
  text-align: center;
  line-height: 1;
}
.mc-icon.ok { color: #4ade80; }
.mc-icon.spin {
  color: #29b6f6;
  display: inline-block;
  animation: spin .9s linear infinite;
}
.mc-icon.pend { color: rgba(238,242,255,.25); }
.mc-row-name {
  font-family: var(--body);
  font-size: 11.5px;
  color: rgba(238,242,255,.75);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.mc-row-meta {
  font-family: var(--mono);
  font-size: 10.5px;
  color: rgba(238,242,255,.40);
  text-align: right;
  white-space: nowrap;
}
.mc-row-meta.ok-text { color: #4ade80; }

/* Progress */
.mc-progress-wrap {
  padding: 10px 14px 8px;
  border-top: 1px solid rgba(255,255,255,.05);
}
.mc-progress-bar {
  height: 4px;
  background: rgba(255,255,255,.08);
  border-radius: 2px;
  overflow: hidden;
  margin-bottom: 6px;
}
.mc-progress-fill {
  height: 100%;
  background: linear-gradient(to right, var(--accent), var(--accent-light));
  border-radius: 2px;
  animation: progressGrow 2s ease-out forwards;
}
.mc-progress-meta {
  display: flex;
  justify-content: space-between;
  font-family: var(--mono);
  font-size: 9.5px;
  color: rgba(238,242,255,.40);
}
.mc-progress-num { color: rgba(238,242,255,.30); }

/* XML snippet */
.mc-xml {
  padding: 10px 14px 12px;
  border-top: 1px solid rgba(255,255,255,.05);
}
.mc-xml-label {
  font-family: var(--mono);
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(238,242,255,.25);
  margin-bottom: 6px;
}
.mc-xml-code {
  background: rgba(0,0,0,.30);
  border: 1px solid rgba(255,255,255,.04);
  border-radius: 6px;
  padding: 8px 10px;
  display: flex;
  flex-direction: column;
  gap: 1px;
}
.xl-ln {
  display: block;
  font-family: var(--mono);
  font-size: 10.5px;
  line-height: 1.7;
  white-space: nowrap;
}
.xl-i1 { padding-left: 12px; }
.xl-i2 { padding-left: 24px; }
.xl-t { color: rgba(238,242,255,.35); }
.xl-e { color: #93c5fd; }
.xl-v { color: #86efac; }
.xl-c { color: rgba(238,242,255,.25); }
.xl-dim { opacity: .45; }

/* Floating badge */
.mockup-badge {
  position: absolute;
  bottom: -14px;
  right: -12px;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 7px 13px;
  background: rgba(13,20,45,.90);
  border: 1px solid rgba(3,169,244,.30);
  border-radius: 999px;
  font-family: var(--mono);
  font-size: 10.5px;
  font-weight: 600;
  letter-spacing: 0.04em;
  color: rgba(238,242,255,.70);
  backdrop-filter: blur(16px);
  box-shadow: 0 4px 24px rgba(0,0,0,.40);
}
.badge-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: #4ade80;
  box-shadow: 0 0 0 3px rgba(74,222,128,.20);
  flex: none;
}

/* Hero bottom fade */
.hero-fade {
  position: absolute;
  left: 0; right: 0; bottom: 0;
  height: 200px;
  z-index: 1;
  pointer-events: none;
  background: linear-gradient(to top, var(--paper) 0%, transparent 100%);
}

/* Animations */
@keyframes pulseDot {
  0%, 100% { box-shadow: 0 0 0 3px rgba(3,169,244,.20); }
  50%       { box-shadow: 0 0 0 5px rgba(3,169,244,.08); }
}
@keyframes spin {
  to { transform: rotate(360deg); }
}
@keyframes progressGrow {
  from { width: 0; }
}

/* =============================================================
   RESPONSIVE
   ============================================================= */
@media (max-width: 1080px) {
  .hero-layout {
    grid-template-columns: 1fr;
    padding-top: 100px;
    padding-bottom: 60px;
  }
  .hero-mockup-wrap { display: none; }
  .hero-h1 { font-size: clamp(36px, 6vw, 54px); }
  .hero-lead { max-width: 60ch; }
}

@media (max-width: 720px) {
  .s-hero { min-height: 100svh; }
  .hero-layout {
    padding-top: 84px;
    padding-bottom: 48px;
    gap: 0;
  }
  .hero-h1 {
    font-size: clamp(34px, 9vw, 48px);
    line-height: 1.08;
  }
  .hero-actions .btn { flex: 1; justify-content: center; }
  .ha { animation-duration: .5s; }
  .ha.d1 { animation-delay: 0s; }
  .ha.d2 { animation-delay: .07s; }
  .ha.d3 { animation-delay: .14s; }
  .ha.d4 { animation-delay: .22s; }
  .ha.d5 { animation-delay: .32s; }
}

@media (prefers-reduced-motion: reduce) {
  .ha { animation: none; opacity: 1; transform: none; }
  .hero-blob { animation: none; }
  .mc-status-dot { animation: none; }
  .mc-icon.spin { animation: none; }
  .mc-progress-fill { animation: none; }
}
</style>
