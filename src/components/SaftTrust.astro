---
// SaftTrust.astro — Trust / expertise / background section
---

<section class="s-trust" id="trust" aria-labelledby="trust-h2">
  <div class="container">

    <div class="trust-layout">

      <!-- Left: statement -->
      <div class="trust-statement">
        <div class="eyebrow">Досвід та надійність</div>
        <h2 id="trust-h2" class="trust-h2">
          Розроблено командою з реальним досвідом у SAF-T
        </h2>
        <p class="trust-lead">
          SAF-T Connector створений командою LUCAS, яка поєднує аудиторів,
          бухгалтерів-практиків, фахівців з оподаткування та розробників ПЗ.
          Ми реалізовували SAF-T UA для великих платників ще на стадії
          пілотного запровадження стандарту — до появи готових ринкових рішень.
        </p>
        <p class="trust-body">
          На відміну від універсальних XML-конверторів, SAF-T Connector розроблений
          під Ukrainian Accounting Standards, специфіку локальних ERP-конфігурацій
          та вимоги ДПС. Кожне оновлення схеми ДПС впроваджується у продукт
          без додаткових витрат для клієнтів на технічній підтримці.
        </p>
        <a href="https://www.lucasua.com" target="_blank" rel="noopener" class="trust-link">
          Про компанію LUCAS →
        </a>
      </div>

      <!-- Right: credentials grid -->
      <div class="trust-creds">
        <div class="cred-card">
          <div class="cred-val">SAF-T UA</div>
          <div class="cred-lbl">Спеціалізація на українському стандарті</div>
        </div>
        <div class="cred-card">
          <div class="cred-val">XSD</div>
          <div class="cred-lbl">Валідація за XSD-схемою ДПС</div>
        </div>
        <div class="cred-card">
          <div class="cred-val">10+ систем</div>
          <div class="cred-lbl">SAP, Oracle, MS Dynamics та інші</div>
        </div>
        <div class="cred-card">
          <div class="cred-val">4–8 тиж.</div>
          <div class="cred-lbl">Типовий термін впровадження</div>
        </div>
      </div>
    </div>

    <!-- Credential badges / trust signals -->
    <div class="trust-badges" role="list" aria-label="Характеристики продукту">
      <div class="trust-badge" role="listitem">
        <div class="tb-icon" aria-hidden="true">
          <svg viewBox="0 0 20 20" fill="none">
            <path d="M10 2 L18 6 V11 C18 15.4 14.5 19.2 10 20.5 C5.5 19.2 2 15.4 2 11 V6 Z" stroke="currentColor" stroke-width="1.2" fill="rgba(29,78,216,.08)"/>
            <path d="M7 10 L9 12.5 L13 8" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <span class="tb-text">Відповідність наказу Мінфіну</span>
      </div>
      <div class="trust-badge" role="listitem">
        <div class="tb-icon" aria-hidden="true">
          <svg viewBox="0 0 20 20" fill="none">
            <circle cx="10" cy="10" r="7.5" stroke="currentColor" stroke-width="1.2" fill="rgba(29,78,216,.08)"/>
            <path d="M7 10 L9 12 L13 8" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <span class="tb-text">Оновлення при зміні схеми ДПС</span>
      </div>
      <div class="trust-badge" role="listitem">
        <div class="tb-icon" aria-hidden="true">
          <svg viewBox="0 0 20 20" fill="none">
            <rect x="3" y="5" width="14" height="11" rx="2" stroke="currentColor" stroke-width="1.2" fill="rgba(29,78,216,.08)"/>
            <path d="M7 9 H13 M7 12 H10" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
        </div>
        <span class="tb-text">Детальна технічна документація</span>
      </div>
      <div class="trust-badge" role="listitem">
        <div class="tb-icon" aria-hidden="true">
          <svg viewBox="0 0 20 20" fill="none">
            <circle cx="8" cy="8" r="4" stroke="currentColor" stroke-width="1.2" fill="rgba(29,78,216,.08)"/>
            <circle cx="13" cy="12" r="4" stroke="currentColor" stroke-width="1.2" fill="rgba(29,78,216,.08)"/>
            <path d="M5 13 L15 7" stroke="currentColor" stroke-width="1" stroke-dasharray="2 1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <span class="tb-text">Технічна підтримка та супровід</span>
      </div>
      <div class="trust-badge" role="listitem">
        <div class="tb-icon" aria-hidden="true">
          <svg viewBox="0 0 20 20" fill="none">
            <rect x="4" y="3" width="12" height="14" rx="2" stroke="currentColor" stroke-width="1.2" fill="rgba(29,78,216,.08)"/>
            <path d="M7 7 H13 M7 10 H11 M7 13 H9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
        </div>
        <span class="tb-text">Аудиторський досвід LUCAS</span>
      </div>
      <div class="trust-badge" role="listitem">
        <div class="tb-icon" aria-hidden="true">
          <svg viewBox="0 0 20 20" fill="none">
            <path d="M3 10 H17 M3 6 H13 M3 14 H10" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
            <path d="M15 8 L18 11 L15 14" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <span class="tb-text">Прямий API до ERP без модифікацій</span>
      </div>
    </div>

  </div>
</section>

<style>
.s-trust {
  background: var(--warm);
  padding: var(--section-py) 0;
  border-top: 1px solid var(--line-strong);
}

.trust-layout {
  display: grid;
  grid-template-columns: 1.1fr .9fr;
  gap: 80px;
  align-items: start;
  margin-bottom: 64px;
}

.trust-statement { display: flex; flex-direction: column; gap: 18px; }
.trust-statement .eyebrow { margin-bottom: 6px; }

.trust-h2 {
  font-family: var(--display);
  font-weight: 500;
  font-size: clamp(26px, 2.6vw, 40px);
  letter-spacing: -0.03em;
  line-height: 1.1;
  color: var(--ink);
}

.trust-lead, .trust-body {
  font-family: var(--body);
  font-size: 16px;
  line-height: 1.7;
  color: var(--ink-soft);
}
.trust-lead { font-size: 17px; color: var(--ink-soft); }

.trust-link {
  display: inline-flex;
  align-items: center;
  font-family: var(--mono);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--accent);
  text-decoration: none;
  transition: opacity .2s var(--ease);
  margin-top: 4px;
}
.trust-link:hover { opacity: .65; }

/* Credentials */
.trust-creds {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}
.cred-card {
  background: var(--paper);
  border: 1px solid var(--line-strong);
  border-radius: 12px;
  padding: 24px 20px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  transition: border-color .25s var(--ease);
}
.cred-card:hover { border-color: rgba(29,78,216,.25); }
.cred-val {
  font-family: var(--display);
  font-size: clamp(22px, 2vw, 30px);
  font-weight: 500;
  letter-spacing: -0.025em;
  color: var(--accent);
  line-height: 1;
}
.cred-lbl {
  font-family: var(--body);
  font-size: 13px;
  line-height: 1.5;
  color: var(--ink-soft);
}

/* Badges */
.trust-badges {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}
.trust-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 16px;
  background: var(--paper);
  border: 1px solid var(--line-strong);
  border-radius: 999px;
  transition: border-color .2s var(--ease);
}
.trust-badge:hover { border-color: rgba(29,78,216,.22); }
.tb-icon { width: 18px; height: 18px; color: var(--accent); flex: none; }
.tb-text {
  font-family: var(--body);
  font-size: 13.5px;
  font-weight: 500;
  color: var(--ink-soft);
  white-space: nowrap;
}

@media (max-width: 1080px) {
  .trust-layout { grid-template-columns: 1fr; gap: 48px; }
  .trust-creds { grid-template-columns: repeat(4, 1fr); }
}
@media (max-width: 900px) {
  .trust-creds { grid-template-columns: repeat(2, 1fr); }
  .trust-badges { gap: 8px; }
  .tb-text { font-size: 12.5px; white-space: normal; }
}
@media (max-width: 720px) {
  .trust-layout { gap: 36px; margin-bottom: 40px; }
}
</style>
