---
// SaftTrust.astro — Trust / expertise / background section
---

<section class="s-trust" id="trust" aria-labelledby="trust-h2">
  <div class="container">

    <div class="trust-layout">

      <!-- Left: statement -->
      <div class="trust-statement">
        <div class="eyebrow">Досвід та відповідальність</div>
        <h2 id="trust-h2" class="trust-h2">
          Чому SAF-T Connector від LUCAS
        </h2>
        <p class="trust-lead">
          LUCAS розробляє SAF-T Connector і впроваджує його власними командами —
          фінансових консультантів і розробників. Немає розподілу відповідальності
          між постачальником програмного забезпечення та консультантами. Ми - єдиний
          центр відповідальності за продукт і його впровадження.
        </p>
        <p class="trust-body">
          LUCAS має практичний досвід участі у пілотному проєкті з впровадження
          SAF-T UA для великого міжнародного клієнта разом із представниками
          ДПС України. Цей досвід важливий, оскільки SAF-T UA є великим і технічно
          складним стандартом, де успіх залежить від якості даних, логіки мапінгу,
          обліково-правових підходів, специфіки ERP та валідації.
          Продукт розроблений аудиторами та фінансовими консультантами для
          бухгалтерських і фінансових команд.
        </p>
        <a href="https://www.lucasua.com" target="_blank" rel="noopener" class="trust-link" aria-label="Про компанію LUCAS — зовнішній сайт">
          Про компанію LUCAS →
        </a>
      </div>

      <!-- Right: credentials grid -->
      <div class="trust-creds">
        <div class="cred-card">
          <div class="cred-val">Власна розробка</div>
          <div class="cred-lbl">LUCAS відповідає і за продукт, і за його впровадження</div>
        </div>
        <div class="cred-card">
          <div class="cred-val">Пілот ДПС</div>
          <div class="cred-lbl">Команда з досвідом участі в пілотному проєкті</div>
        </div>
        <div class="cred-card">
          <div class="cred-val">Єдина команда</div>
          <div class="cred-lbl">Фінансові консультанти та розробники LUCAS</div>
        </div>
        <div class="cred-card">
          <div class="cred-val">~3–4 міс.</div>
          <div class="cred-lbl">Типовий термін впровадження</div>
        </div>
      </div>
    </div>

    <!-- Credential badges / trust signals -->
    <div class="trust-badges" role="list" aria-label="Характеристики продукту">
      <div class="trust-badge" role="listitem">
        <div class="tb-icon" aria-hidden="true">
          <svg viewBox="0 0 20 20" fill="none">
            <path d="M10 2l8 3v5C18 14.5 14.5 18 10 19.5 5.5 18 2 14.5 2 10V5Z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
            <path d="M7 10.5l2.5 2.5 4-4.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <span class="tb-text">Відповідність вимогам Мінфіну та ДПС</span>
      </div>
      <div class="trust-badge" role="listitem">
        <div class="tb-icon" aria-hidden="true">
          <svg viewBox="0 0 20 20" fill="none">
            <path d="M4 10A6.5 6.5 0 0 1 14.5 5.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
            <path d="M16 10A6.5 6.5 0 0 1 5.5 14.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
            <path d="M11.5 3l3 2.5-2.5 2.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M8.5 17l-3-2.5 2.5-2.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <span class="tb-text">Оновлення при зміні офіційної схеми</span>
      </div>
      <div class="trust-badge" role="listitem">
        <div class="tb-icon" aria-hidden="true">
          <svg viewBox="0 0 20 20" fill="none">
            <rect x="2" y="4" width="16" height="13" rx="2" stroke="currentColor" stroke-width="1.3"/>
            <path d="M2 8.5h16M2 12.5h16" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
            <path d="M7.5 4v13M12.5 4v13" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
        </div>
        <span class="tb-text">Excel-перегляд SAF-T UA</span>
      </div>
      <div class="trust-badge" role="listitem">
        <div class="tb-icon" aria-hidden="true">
          <svg viewBox="0 0 20 20" fill="none">
            <path d="M4 10a6 6 0 0 1 12 0" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
            <rect x="2.5" y="9.5" width="3" height="4.5" rx="1" stroke="currentColor" stroke-width="1.2"/>
            <rect x="14.5" y="9.5" width="3" height="4.5" rx="1" stroke="currentColor" stroke-width="1.2"/>
            <path d="M16 14v1.5a2.5 2.5 0 0 1-2.5 2.5H11" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
        </div>
        <span class="tb-text">Технічна підтримка та супровід</span>
      </div>
      <div class="trust-badge" role="listitem">
        <div class="tb-icon" aria-hidden="true">
          <svg viewBox="0 0 20 20" fill="none">
            <polygon points="10,2 12.1,7.2 17.6,7.5 13.3,11.1 14.7,16.5 10,13.5 5.3,16.5 6.7,11.1 2.4,7.5 7.9,7.2" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
          </svg>
        </div>
        <span class="tb-text">Аудиторський та фінансовий досвід LUCAS</span>
      </div>
      <div class="trust-badge" role="listitem">
        <div class="tb-icon" aria-hidden="true">
          <svg viewBox="0 0 20 20" fill="none">
            <rect x="2" y="3" width="16" height="5" rx="1.5" stroke="currentColor" stroke-width="1.3"/>
            <rect x="2" y="11" width="16" height="5" rx="1.5" stroke="currentColor" stroke-width="1.3"/>
            <circle cx="15" cy="5.5" r="1" fill="currentColor" stroke="none"/>
            <circle cx="12.5" cy="5.5" r="1" fill="currentColor" stroke="none"/>
            <circle cx="15" cy="13.5" r="1" fill="currentColor" stroke="none"/>
            <circle cx="12.5" cy="13.5" r="1" fill="currentColor" stroke="none"/>
          </svg>
        </div>
        <span class="tb-text">Розгортання на інфраструктурі клієнта</span>
      </div>
    </div>

  </div>
</section>

<style>
.s-trust {
  background: var(--warm);
  padding: var(--section-py) 0;
  border-top: 1px solid var(--line-strong);
  overflow: hidden;
}

.trust-layout {
  display: grid;
  grid-template-columns: 1.1fr .9fr;
  gap: 80px;
  align-items: start;
  margin-bottom: 64px;
}

.trust-statement { display: flex; flex-direction: column; gap: 18px; }
.trust-statement .eyebrow { margin-bottom: 6px; }

.trust-h2 {
  font-family: var(--display);
  font-weight: 500;
  font-size: clamp(26px, 2.6vw, 40px);
  letter-spacing: -0.03em;
  line-height: 1.1;
  color: var(--ink);
}

.trust-lead, .trust-body {
  font-family: var(--body);
  font-size: 16px;
  line-height: 1.7;
  color: var(--ink-soft);
}
.trust-lead { font-size: 17px; color: var(--ink-soft); }

.trust-link {
  display: inline-flex;
  align-items: center;
  font-family: var(--mono);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--accent-light);
  text-decoration: none;
  transition: color .2s var(--ease);
  margin-top: 4px;
}
.trust-link:hover { color: var(--accent); }
.trust-link:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; border-radius: 2px; }

/* Credentials */
.trust-creds {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}
.cred-card {
  background: var(--paper);
  border: 1px solid var(--line-strong);
  border-radius: 12px;
  padding: 24px 20px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  transition: border-color .25s var(--ease);
}
.cred-card:hover { border-color: rgba(3,169,244,.25); }
.cred-val {
  font-family: var(--display);
  font-size: clamp(22px, 2vw, 30px);
  font-weight: 500;
  letter-spacing: -0.025em;
  color: var(--accent);
  line-height: 1;
}
.cred-lbl {
  font-family: var(--body);
  font-size: 13px;
  line-height: 1.5;
  color: var(--ink-soft);
}

/* Badges */
.trust-badges {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}
.trust-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 16px;
  background: var(--paper);
  border: 1px solid var(--line-strong);
  border-radius: 999px;
  transition: border-color .2s var(--ease);
}
.trust-badge:hover { border-color: rgba(3,169,244,.22); }
.tb-icon { width: 18px; height: 18px; color: var(--accent); flex: none; }
.tb-text {
  font-family: var(--body);
  font-size: 13.5px;
  font-weight: 500;
  color: var(--ink-soft);
  white-space: nowrap;
}

@media (max-width: 1080px) {
  .trust-layout { grid-template-columns: 1fr; gap: 48px; }
  .trust-creds { grid-template-columns: repeat(4, 1fr); }
}
@media (max-width: 900px) {
  .trust-creds { grid-template-columns: repeat(2, 1fr); }
  .trust-badges { gap: 8px; }
  .tb-text { font-size: 12.5px; white-space: normal; }
}
@media (max-width: 720px) {
  .trust-layout { gap: 36px; margin-bottom: 40px; }
}
</style>
