---
// Footer.astro — SAF-T Connector
const currentYear = new Date().getFullYear();
---
<footer class="footer">
  <div class="footer-inner">
    <div class="footer-grid">

      <!-- Brand column -->
      <div class="footer-brand">
        <a href={import.meta.env.BASE_URL} class="footer-logo" aria-label="SAF-T Connector — на головну">
          <img src={`${import.meta.env.BASE_URL}logo-white.svg`} class="footer-logo-img" alt="" width="111" height="30" />
        </a>
        <p class="footer-tagline">
          Формування XML-файлу та XSD-валідація відповідно до вимог е-аудиту ДПС України.
        </p>
        <p class="footer-legal">
          Продукт компанії LUCAS<br>
          lucasua.com
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <p class="footer-col-label">Продукт</p>
        <ul>
          <li><a href="#explainer">Що таке SAF-T</a></li>
          <li><a href="#benefits">Можливості</a></li>
          <li><a href="#erp">ERP-системи</a></li>
          <li><a href="#how-it-works">Реалізація</a></li>
          <li><a href="#validation">Валідація XML</a></li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <p class="footer-col-label">Ресурси</p>
        <ul>
          <li><a href="#faq">FAQ</a></li>
          <li><a href="https://www.lucasua.com/saf-t/" target="_blank" rel="noopener">Сторінка послуги</a></li>
          <li><a href="https://www.lucasua.com/blog/saf-t-ukraina-povny-gayd/" target="_blank" rel="noopener">Гайд по SAF-T UA</a></li>
          <li><a href="https://www.lucasua.com/blog/saf-t-validatsiya-xsd-pomylky/" target="_blank" rel="noopener">Валідація XSD</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="footer-contact">
        <p class="footer-col-label">Зв'язок</p>
        <div class="footer-contact-row">
          <span class="footer-contact-lbl">Запит на демо</span>
          <a href="mailto:info@lucasua.com" class="footer-contact-val">info@lucasua.com</a>
        </div>
        <div class="footer-contact-row">
          <span class="footer-contact-lbl">Телефон</span>
          <a href="tel:+380443447915" class="footer-contact-val">+38 (044) 344-79-15</a>
        </div>
        <div class="footer-contact-row">
          <span class="footer-contact-lbl">Адреса</span>
          <span class="footer-contact-val">Київ, БЦ Гулівер, вежа А, 17-й поверх</span>
        </div>
      </div>
    </div>

    <div class="footer-bot">
      <span class="footer-bot-copy">© {currentYear} LUCAS. SAF-T Connector. Усі права захищені.</span>
      <a href="https://www.lucasua.com" target="_blank" rel="noopener" class="footer-bot-accent" aria-label="lucasua.com — зовнішній сайт">lucasua.com →</a>
    </div>
  </div>
</footer>
