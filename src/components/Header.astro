---
// Header.astro — SAF-T Connector
// Sticky header with transparent-over-dark-hero → scrolled-light transition
---

<header class="header" id="header">
  <div class="header-inner">

    <!-- Logo — base-aware href works under any subpath or root -->
    <a href={import.meta.env.BASE_URL} class="logo" aria-label="SAF-T Connector — на головну">
      <div class="logo-mark" aria-hidden="true">
        <svg viewBox="0 0 16 16" aria-hidden="true">
          <rect x="2" y="3" width="5" height="1.5" rx=".5"/>
          <rect x="2" y="6" width="8" height="1.5" rx=".5"/>
          <rect x="2" y="9" width="7" height="1.5" rx=".5"/>
          <rect x="2" y="12" width="9" height="1.5" rx=".5"/>
          <path d="M12 4 L15 8 L12 12" stroke="white" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        </svg>
      </div>
      <span class="logo-text">SAF-T<span class="sep"> </span>Connector</span>
    </a>

    <!-- Desktop nav — fragment-only hrefs work under any base path -->
    <nav class="nav" aria-label="Основна навігація">
      <a href="#explainer">Що таке SAF-T</a>
      <a href="#erp">ERP-системи</a>
      <a href="#how-it-works">Реалізація</a>
      <a href="#validation">Валідація XML</a>
      <a href="#faq">FAQ</a>
      <a href="#contact">Контакти</a>
    </nav>

    <!-- Actions -->
    <div class="header-actions">
      <a class="header-cta" href="#contact">Замовити демо</a>
      <button
        aria-expanded="false"
        aria-label="Відкрити меню"
        class="mob-menu-btn"
        id="mob-menu-btn"
      >
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile slide-in panel -->
<div inert class="mob-menu" id="mob-menu" role="dialog" aria-label="Навігаційне меню">
  <span class="mob-section-label">Навігація</span>
  <a href="#explainer">Що таке SAF-T</a>
  <a href="#erp">ERP-системи</a>
  <a href="#how-it-works">Реалізація</a>
  <a href="#validation">Валідація XML</a>
  <a href="#faq">FAQ</a>
  <a href="#contact">Контакти</a>
  <span class="mob-section-label">Дія</span>
  <a href="#contact" class="mob-cta-link">Замовити демо →</a>
</div>

<div class="mob-overlay" id="mob-overlay"></div>

<style>
  .mob-cta-link {
    color: #fff !important;
    font-weight: 600 !important;
    letter-spacing: -0.01em;
  }
</style>

<script is:inline>
  (() => {
    const header = document.getElementById('header');
    if (!header) return;
    const scrim  = document.getElementById('page-scrim');

    const onScroll = () => {
      const hero = document.querySelector('.s-hero');
      const threshold = hero ? hero.getBoundingClientRect().bottom : 80;
      const past = threshold <= 60;
      header.classList.toggle('scrolled', past);
      if (scrim) scrim.classList.toggle('light', past);
    };

    if (window.scrollY > 0) requestAnimationFrame(onScroll);
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll);
  })();

  (() => {
    const btn     = document.getElementById('mob-menu-btn');
    const menu    = document.getElementById('mob-menu');
    const overlay = document.getElementById('mob-overlay');
    if (!btn || !menu || !overlay) return;

    const open = () => {
      btn.classList.add('is-open');
      menu.classList.add('is-open');
      overlay.classList.add('is-open');
      menu.removeAttribute('inert');
      btn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    };
    const close = () => {
      btn.classList.remove('is-open');
      menu.classList.remove('is-open');
      overlay.classList.remove('is-open');
      menu.setAttribute('inert', '');
      btn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    };

    btn.addEventListener('click', () =>
      menu.classList.contains('is-open') ? close() : open()
    );
    overlay.addEventListener('click', close);
    menu.querySelectorAll('a').forEach(a => a.addEventListener('click', close));
    document.addEventListener('keydown', e => { if (e.key === 'Escape') close(); });
  })();
</script>
